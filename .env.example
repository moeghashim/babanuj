# Babanuj environment variables — copy to .env.local and fill in.
# All NEXT_PUBLIC_ values are exposed to the browser.

# Shopify
SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
NEXT_PUBLIC_SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
SHOPIFY_STOREFRONT_ACCESS_TOKEN=
SHOPIFY_REVALIDATION_SECRET=
SHOPIFY_CUSTOMER_ACCOUNT_CLIENT_ID=
SHOPIFY_CUSTOMER_ACCOUNT_REDIRECT_URI=https://your-domain.com/account/authorize
SESSION_SECRET=

# Site identity
SITE_NAME=Babanuj
COMPANY_NAME="Babanuj Inc."

# Analytics (GA4)
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Product analytics (PostHog) — Project Settings → Project API Key (phc_...).
# Safe to expose; it's a write-only ingest key. Leave blank to disable.
# NEXT_PUBLIC_POSTHOG_HOST is only the dashboard URL used to build links
# (use https://eu.posthog.com for an EU project). Event ingestion is proxied
# through /ingest — see the rewrites in next.config.ts.
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.posthog.com

# Meta ads tracking
NEXT_PUBLIC_META_PIXEL_ID=
META_PIXEL_ID=
META_CAPI_ACCESS_TOKEN=

# Customer support (Shopify Inbox)
NEXT_PUBLIC_SHOPIFY_INBOX_SHOP_ID=

# Wholesale inquiry mailto target
WHOLESALE_EMAIL=wholesale@babanuj.com
